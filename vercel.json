{
  "version": 2,
  "buildCommand": "cd frontend/finance-tracker-frontend && npm run build",
  "outputDirectory": "frontend/finance-tracker-frontend/dist",
  "installCommand": "cd frontend/finance-tracker-frontend && npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/frontend/finance-tracker-frontend/index.html"
    }
  ]
}
